FROM docker.io/mcp/sequentialthinking:latest

# Install supergateway
RUN npm install -g supergateway

# Expose the gateway port
EXPOSE 8080

# Override base entrypoint and run supergateway with the local sequential thinking server
ENTRYPOINT ["supergateway"]
CMD ["--stdio", "node /app/dist/index.js", "--outputTransport", "streamableHttp", "--port", "8080", "--streamableHttpPath", "/mcp"]
